# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Create keys at https://fal.ai/dashboard/keys

# Standard API key — used by generate.php for video generation.
FAL_KEY=your-api-key-here

# Admin-scope key — used by usage.php for billing/usage. Keep this extra safe.
FAL_ADMIN_KEY=your-admin-key-here
